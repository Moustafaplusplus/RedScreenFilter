<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.RedScreenFilter" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/scarlet_core</item>
        <item name="colorOnPrimary">@color/text_primary_on_dark</item>
        <item name="colorPrimaryContainer">@color/card_overlay</item>
        <item name="colorSecondary">@color/ember_orange</item>
        <item name="colorOnSecondary">@color/text_primary_on_dark</item>
        <item name="colorSurface">@color/charcoal_surface</item>
        <item name="colorOnSurface">@color/text_primary_on_dark</item>
        <item name="colorSurfaceVariant">@color/card_overlay</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_on_dark</item>
        <item name="android:windowBackground">@color/carbon_black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/carbon_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialButtonStyle">@style/Widget.RedScreenFilter.Button</item>
        <item name="materialCardViewStyle">@style/Widget.RedScreenFilter.Card</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.RedScreenFilter.Dialog</item>
    </style>

    <style name="Theme.RedScreenFilter" parent="Base.Theme.RedScreenFilter" />

    <style name="Widget.RedScreenFilter.Button" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/scarlet_core</item>
        <item name="android:textColor">@color/text_primary_on_dark</item>
    </style>

    <style name="Widget.RedScreenFilter.Card" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/card_overlay</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ThemeOverlay.RedScreenFilter.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/card_overlay</item>
        <item name="colorOnSurface">@color/text_primary_on_dark</item>
    </style>
</resources>
