<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Overlay Permission -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" tools:ignore="ProtectedPermissions" />
    
    <!-- Foreground Service Permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    
    <!-- Notification Permission for Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Boot Completed Permission for Alarm Scheduling -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Exact Alarm Permissions for Android 12+ -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Location Permissions for Sunrise/Sunset Scheduling -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    
    <!-- App Exemption Permissions -->
    <!-- Required to detect current foreground app -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />

    <!-- Package visibility for Android 11+: launcher apps only (Play policy compliant) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RedScreenFilter"
        tools:targetApi="31">
        
        <!-- Splash as launcher -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.RedScreenFilter">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.RedScreenFilter">
            <!-- Handle Quick Settings Tile Preferences (Long Click) -->
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE_PREFERENCES" />
            </intent-filter>
        </activity>

        <!-- WebView Activity for Docs -->
        <activity
            android:name=".ui.WebViewActivity"
            android:exported="false"
            android:theme="@style/Theme.RedScreenFilter" />

        <!-- Red Overlay Foreground Service -->
        <service
            android:name=".service.RedOverlayService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Screen overlay filter for eye protection">
            </property>
        </service>
        
        <!-- Schedule Receiver for Exact Alarms -->
        <receiver
            android:name=".receiver.ScheduleReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.redscreenfilter.action.SCHEDULE_ALARM" />
            </intent-filter>
        </receiver>

        <!-- Boot Completed Receiver for Re-scheduling Alarms -->
        <receiver
            android:name=".receiver.BootCompletedReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        
        <!-- Quick Settings Tile Service -->
        <service
            android:name=".receiver.OverlayQuickSettingsTile"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
        
        <!-- Voice Command Receiver for Google Assistant Integration -->
        <receiver
            android:name=".receiver.VoiceCommandReceiver"
            android:enabled="true"
            android:exported="true">
            <!-- Handle voice command action -->
            <intent-filter android:priority="100">
                <action android:name="android.intent.action.VOICE_COMMAND" />
            </intent-filter>
            <!-- Handle Google Assistant voice intents -->
            <intent-filter android:priority="100">
                <action android:name="com.google.android.gm.action.AUTO_SEND" />
                <action android:name="android.intent.action.SEND" />
                <action android:name="com.example.android.audioapp.PLAY_SONG" />
            </intent-filter>
            <!-- Handle custom voice control actions -->
            <intent-filter android:priority="100">
                <action android:name="com.redscreenfilter.action.VOICE_CONTROL" />
            </intent-filter>
        </receiver>
        
    </application>

</manifest>